---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site';

interface Props {
	title?: string;
	description?: string;
}

// Static meta uses English (the <title> can't live-toggle); both audiences
// see a clear, bilingual-friendly description.
const {
	title = `${site.couple.one} and ${site.couple.two} — ${site.location.en}`,
	description = `Join ${site.couple.one} and ${site.couple.two} in ${site.location.en} for a three-day wedding weekend, ${site.dateLong.en}. · Feiert mit uns ein dreitägiges Hochzeitswochenende.`,
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- Pick the language before first paint: saved choice wins, else
		     German browsers get German, everyone else English. Inline so the
		     EN/DE CSS toggle is correct on load (no flash). -->
		<script is:inline>
			(function () {
				try {
					var saved = localStorage.getItem('lang');
					var lang =
						saved ||
						((navigator.language || 'en').toLowerCase().indexOf('de') === 0
							? 'de'
							: 'en');
					var el = document.documentElement;
					el.setAttribute('data-lang', lang);
					el.setAttribute('lang', lang);
				} catch (e) {
					document.documentElement.setAttribute('data-lang', 'en');
				}
			})();
		</script>

		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />

		<!-- Fonts. Bodoni Moda (display) + Hanken Grotesk (text) + Tangerine
		     (placeholder for Amalfi Coast, used only on the word "and").
		     TODO: self-host these as woff2 in /public/fonts for performance,
		     and drop in the real Amalfi Coast via @font-face — then point
		     --font-script at it in global.css. -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;0,6..96,500;1,6..96,400;1,6..96,500&family=Hanken+Grotesk:wght@300;400;500&family=Tangerine:wght@400;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<Nav />
		<main id="top">
			<slot />
		</main>
		<Footer />

		<script>
			// Progressive enhancement only: mark that JS is on, then reveal
			// sections as they enter the viewport. Content is fully visible
			// without JS and for reduced-motion users.
			document.documentElement.classList.add('js');
			const els = document.querySelectorAll<HTMLElement>('.reveal');
			if ('IntersectionObserver' in window) {
				const io = new IntersectionObserver(
					(entries) => {
						for (const e of entries) {
							if (e.isIntersecting) {
								e.target.classList.add('is-in');
								io.unobserve(e.target);
							}
						}
					},
					{ rootMargin: '0px 0px -10% 0px', threshold: 0.1 },
				);
				els.forEach((el) => io.observe(el));
			} else {
				els.forEach((el) => el.classList.add('is-in'));
			}
		</script>
	</body>
</html>
