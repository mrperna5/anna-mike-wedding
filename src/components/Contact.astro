---
import { site } from '../data/site';
import { contact } from '../data/copy';
import Bi from './Bi.astro';
---

<section id="contact" class="section section--alt">
	<div class="container contact reveal measure">
		<p class="kicker"><Bi t={contact.kicker} /></p>
		<h2 class="contact__head"><Bi t={contact.title} /></h2>
		<p><Bi t={contact.p} /></p>
		<a class="link contact__link" href={`mailto:${site.email}`}>{site.email}</a>
	</div>
</section>

<style>
	.contact__head {
		font-size: var(--fs-h1);
		margin: 1rem 0 1.5rem;
	}
	.contact__link {
		display: inline-block;
		margin-top: 1rem;
		font-size: 0.78rem;
	}
</style>
