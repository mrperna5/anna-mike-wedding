---
import { story } from '../data/copy';
import Bi from './Bi.astro';
---

<section id="story" class="section">
	<div class="container story">
		<div class="story__text reveal">
			<p class="kicker"><Bi t={story.kicker} /></p>
			<p class="lede story__lede"><Bi t={story.lede} /></p>
			<p><Bi t={story.p} /></p>
		</div>

		<!-- Full-bleed photographic moment — replace flat field with a photo. -->
		<figure class="story__photo photo reveal">
			<figcaption class="photo__cap"><Bi t={story.caption} /></figcaption>
		</figure>
	</div>
</section>

<style>
	.story {
		display: grid;
		gap: clamp(2rem, 5vw, 4rem);
		align-items: center;
	}
	.story__lede {
		margin: 1.25rem 0 1.75rem;
	}
	.story__photo {
		height: clamp(18rem, 60vw, 32rem);
	}
	@media (min-width: 48rem) {
		.story {
			grid-template-columns: 1fr 1fr;
		}
	}
</style>
