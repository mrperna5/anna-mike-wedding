---
import { venue } from '../data/copy';
import Bi from './Bi.astro';
---

<section id="venue" class="section">
	<figure class="venue__photo photo reveal">
		<figcaption class="photo__cap"><Bi t={venue.caption} /></figcaption>
	</figure>

	<div class="container venue__grid">
		<div class="venue__intro reveal">
			<p class="kicker"><Bi t={venue.kicker} /></p>
			<h2 class="venue__head"><Bi t={venue.title} /></h2>
			<p class="measure"><Bi t={venue.intro} /></p>
		</div>

		<dl class="venue__facts reveal">
			{
				venue.facts.map((f) => (
					<div class="venue__fact">
						<dt>
							<Bi t={f.label} />
						</dt>
						<dd>
							<Bi t={f.value} />
						</dd>
					</div>
				))
			}
		</dl>
	</div>
</section>

<style>
	.venue__photo {
		height: clamp(16rem, 50vw, 30rem);
		margin: 0 0 clamp(2.5rem, 6vw, 4rem);
	}
	.venue__grid {
		display: grid;
		gap: clamp(2rem, 5vw, 4rem);
	}
	.venue__head {
		font-size: var(--fs-h1);
		margin: 1rem 0 1.5rem;
	}
	.venue__facts {
		margin: 0;
	}
	.venue__fact {
		padding: 1rem 0;
		border-top: 1px solid var(--hairline);
	}
	.venue__fact:last-child {
		border-bottom: 1px solid var(--hairline);
	}
	.venue__fact dt {
		font-size: var(--fs-label);
		letter-spacing: var(--track-wide);
		text-transform: uppercase;
		color: var(--olive-muted);
		margin-bottom: 0.3rem;
	}
	.venue__fact dd {
		margin: 0;
		font-family: var(--font-display);
		font-size: var(--fs-h3);
		color: var(--ink);
	}
	@media (min-width: 48rem) {
		.venue__grid {
			grid-template-columns: 1.2fr 1fr;
			align-items: start;
		}
	}
</style>
