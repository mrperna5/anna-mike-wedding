---
import { overview } from '../data/copy';
import Bi from './Bi.astro';
---

<section id="overview" class="section section--alt">
	<div class="container overview reveal">
		<p class="kicker"><Bi t={overview.kicker} /></p>
		<h2 class="overview__head">
			<span class="bi" data-lang="en" set:html={overview.headEn} />
			<span class="bi" data-lang="de" lang="de" set:html={overview.headDe} />
		</h2>
		<div class="overview__body measure">
			<p><Bi t={overview.p1} /></p>
			<p><Bi t={overview.p2} /></p>
		</div>
	</div>
</section>

<style>
	.overview__head {
		font-size: var(--fs-h1);
		margin: 1.25rem 0 2rem;
	}
	.overview__body {
		font-size: var(--fs-h3);
		line-height: 1.7;
	}
	.overview__body p {
		margin-bottom: 1.5rem;
	}
</style>
