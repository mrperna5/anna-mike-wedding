---
import { site } from '../data/site';
---

<section id="overview" class="section section--alt">
	<div class="container overview reveal">
		<p class="kicker">The weekend</p>
		<h2 class="overview__head">
			Three days among<br />the cypresses
		</h2>
		<div class="overview__body measure">
			<p>
				We didn’t want a wedding that was over in an evening. So we’re asking
				the people we love to set aside a long weekend in {site.region} — to
				eat slowly, stay up late, and be together somewhere beautiful.
			</p>
			<p>
				Pizza on Friday, vows on Saturday, and nowhere to be on Sunday.
				Everything below is here to help you plan the trip.
			</p>
		</div>
	</div>
</section>

<style>
	.overview__head {
		font-size: var(--fs-h1);
		margin: 1.25rem 0 2rem;
	}
	.overview__body {
		font-size: var(--fs-h3);
		line-height: 1.7;
	}
	.overview__body p {
		margin-bottom: 1.5rem;
	}
</style>
