---
import { site, nav } from '../data/site';
import { ui } from '../data/copy';
import Bi from './Bi.astro';
const monogram = `${site.couple.one[0]}${site.couple.two[0]}`;
---

<header class="nav">
	<div class="nav__bar container">
		<a class="nav__mono" href="#top" aria-label="Back to top">{monogram}</a>

		<nav class="nav__links" aria-label="Sections">
			{nav.map((item) => (
				<a href={`#${item.id}`}><Bi t={item.label} /></a>
			))}
		</nav>

		<div class="nav__right">
			<div class="lang" role="group" aria-label="Language / Sprache">
				<button type="button" class="lang__btn" data-set-lang="en">EN</button>
				<span class="lang__sep" aria-hidden="true">/</span>
				<button type="button" class="lang__btn" data-set-lang="de">DE</button>
			</div>
			<button
				class="nav__toggle"
				aria-expanded="false"
				aria-controls="nav-overlay"
			>
				<Bi t={ui.menu} />
			</button>
		</div>
	</div>

	<div class="nav__overlay" id="nav-overlay" hidden>
		<nav aria-label="Sections">
			{nav.map((item) => (
				<a href={`#${item.id}`}><Bi t={item.label} /></a>
			))}
		</nav>
	</div>
</header>

<style>
	.nav {
		position: sticky;
		top: 0;
		z-index: 50;
		background: color-mix(in srgb, var(--cream) 88%, transparent);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid var(--hairline);
	}
	.nav__bar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		min-height: 60px;
		gap: 1rem;
	}
	.nav__mono {
		font-family: var(--font-display);
		font-size: 1.15rem;
		letter-spacing: 0.25em;
		color: var(--olive);
		text-decoration: none;
		padding-left: 0.06em;
	}
	.nav__links {
		display: none;
		gap: clamp(0.9rem, 2vw, 1.9rem);
	}
	.nav__links a {
		font-size: var(--fs-label);
		letter-spacing: var(--track-wide);
		text-transform: uppercase;
		font-weight: 500;
		color: var(--ink-soft);
		text-decoration: none;
		transition: color 0.25s var(--ease);
	}
	.nav__links a:hover {
		color: var(--terracotta);
	}
	.nav__right {
		display: flex;
		align-items: center;
		gap: 1.1rem;
	}
	.lang {
		display: flex;
		align-items: center;
		gap: 0.4rem;
	}
	.lang__btn {
		font-family: var(--font-sans);
		font-size: var(--fs-label);
		letter-spacing: var(--track-wide);
		font-weight: 500;
		color: var(--olive-muted);
		background: none;
		border: 0;
		padding: 0.2rem 0;
		cursor: pointer;
		transition: color 0.25s var(--ease);
	}
	.lang__btn:hover {
		color: var(--ink);
	}
	.lang__sep {
		color: var(--hairline);
		font-size: var(--fs-label);
	}
	:global(html[data-lang='en']) .lang__btn[data-set-lang='en'],
	:global(html[data-lang='de']) .lang__btn[data-set-lang='de'] {
		color: var(--terracotta);
	}
	.nav__toggle {
		font-family: var(--font-sans);
		font-size: var(--fs-label);
		letter-spacing: var(--track-wide);
		text-transform: uppercase;
		font-weight: 500;
		color: var(--ink);
		background: none;
		border: 0;
		padding: 0.4rem 0;
		cursor: pointer;
	}
	.nav__overlay {
		border-top: 1px solid var(--hairline);
		background: var(--cream);
	}
	.nav__overlay nav {
		display: flex;
		flex-direction: column;
		padding: 0.5rem var(--gutter) 1.5rem;
	}
	.nav__overlay a {
		font-family: var(--font-display);
		font-size: 1.35rem;
		color: var(--ink);
		text-decoration: none;
		padding: 0.6rem 0;
		border-bottom: 1px solid var(--hairline);
	}

	@media (min-width: 64rem) {
		.nav__links {
			display: flex;
		}
		.nav__toggle,
		.nav__overlay {
			display: none;
		}
	}
</style>

<script>
	// Language toggle — set <html data-lang>, persist, update lang attr.
	document.querySelectorAll<HTMLButtonElement>('.lang__btn').forEach((btn) => {
		btn.addEventListener('click', () => {
			const lang = btn.dataset.setLang || 'en';
			document.documentElement.setAttribute('data-lang', lang);
			document.documentElement.setAttribute('lang', lang);
			try {
				localStorage.setItem('lang', lang);
			} catch (e) {
				/* ignore */
			}
		});
	});

	// Mobile menu overlay.
	const toggle = document.querySelector<HTMLButtonElement>('.nav__toggle');
	const overlay = document.getElementById('nav-overlay');
	if (toggle && overlay) {
		const setOpen = (open: boolean) => {
			overlay.hidden = !open;
			toggle.setAttribute('aria-expanded', String(open));
		};
		toggle.addEventListener('click', () =>
			setOpen(toggle.getAttribute('aria-expanded') !== 'true'),
		);
		overlay.querySelectorAll('a').forEach((a) =>
			a.addEventListener('click', () => setOpen(false)),
		);
	}
</script>
