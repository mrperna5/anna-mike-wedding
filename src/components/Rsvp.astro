---
import { site } from '../data/site';
// Visual only for now — no form, no backend. When you're ready to collect
// replies, wire this to a static-friendly service (e.g. a styled form
// posting to Formspree/Tally). Nothing here submits yet.
---

<section id="rsvp" class="section">
	<div class="container rsvp reveal">
		<p class="kicker rsvp__kicker">With love</p>
		<h2 class="rsvp__head">
			Will you<span class="couple__and rsvp__and">join</span>us?
		</h2>
		<p class="rsvp__sub measure">
			RSVPs will open right here in the new year. For now, save the dates,
			book a bed, and tell us you’re coming when the form goes live.
		</p>
		<p class="rsvp__pill">RSVP opening soon</p>
		<p class="rsvp__meta">{site.location} · {site.dateLong}</p>
	</div>
</section>

<style>
	.rsvp {
		text-align: center;
	}
	.rsvp__kicker {
		margin-bottom: 1.5rem;
	}
	.rsvp__head {
		font-size: var(--fs-h1);
		margin: 0 0 1.75rem;
	}
	.rsvp__and {
		display: inline;
		font-size: 1.05em;
		margin: 0 0.18em;
		vertical-align: -0.08em;
	}
	.rsvp__sub {
		margin: 0 auto 2.25rem;
		font-size: var(--fs-h3);
		line-height: 1.7;
	}
	.rsvp__pill {
		display: inline-block;
		font-size: var(--fs-label);
		letter-spacing: var(--track-label);
		text-transform: uppercase;
		font-weight: 500;
		color: var(--olive);
		border: 1px solid var(--olive);
		border-radius: 999px;
		padding: 0.85rem 1.75rem;
		margin: 0 0 2rem;
	}
	.rsvp__meta {
		font-size: var(--fs-label);
		letter-spacing: var(--track-wide);
		text-transform: uppercase;
		color: var(--olive-muted);
		margin: 0;
	}
</style>
