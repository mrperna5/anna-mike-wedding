---
import { travel } from '../data/copy';
import Bi from './Bi.astro';
---

<section id="travel" class="section section--alt">
	<div class="container">
		<header class="travel__head reveal">
			<p class="kicker"><Bi t={travel.kicker} /></p>
			<h2 class="travel__title"><Bi t={travel.title} /></h2>
			<p class="measure"><Bi t={travel.intro} /></p>
		</header>

		<ol class="travel__steps">
			{
				travel.steps.map((s) => (
					<li class="travel__step reveal">
						<p class="travel__label">
							<Bi t={s.label} />
						</p>
						<h3 class="travel__name">
							<Bi t={s.title} />
						</h3>
						<p class="travel__body">
							<Bi t={s.body} />
						</p>
					</li>
				))
			}
		</ol>
	</div>
</section>

<style>
	.travel__head {
		margin-bottom: clamp(2.5rem, 6vw, 4rem);
	}
	.travel__title {
		font-size: var(--fs-h1);
		margin: 1rem 0 1.5rem;
	}
	.travel__steps {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: clamp(1.5rem, 4vw, 2.5rem);
	}
	.travel__step {
		padding-top: 1.25rem;
		border-top: 1px solid var(--hairline);
	}
	.travel__label {
		font-size: var(--fs-label);
		letter-spacing: var(--track-label);
		text-transform: uppercase;
		color: var(--terracotta);
		margin: 0 0 0.75rem;
	}
	.travel__name {
		font-size: var(--fs-h3);
		margin: 0 0 0.65rem;
	}
	.travel__body {
		margin: 0;
		font-size: var(--fs-small);
	}
	@media (min-width: 48rem) {
		.travel__steps {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
